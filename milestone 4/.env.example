# Turso Database (libsql cloud)
TURSO_DATABASE_URL=libsql://your-db-name.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=your_token_here

# Telegram Notifications (Milestone 4 - optional)
# Set ENABLE_NOTIFICATIONS=true to send Telegram messages on changes
# Get bot token from BotFather: https://t.me/botfather
# Get your chat ID from: https://t.me/userinfobot
ENABLE_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scraper options (can be overridden via CLI)
MAX_MISS_COUNT=3
